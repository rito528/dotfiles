#!/usr/bin/env bash
set -euo pipefail

if ! command -v gitleaks &>/dev/null; then
  echo "gitleaks is not installed. Cannot secret check."
  exit 1
fi

gitleaks protect --staged --redact

staged_files=()
while IFS= read -r -d '' file; do
  staged_files+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACM -z)

# editorconfig チェック (staged ファイルのみ)
if ! command -v editorconfig-checker &>/dev/null; then
  echo "editorconfig-checker is not installed. Cannot editorconfig check."
  exit 1
fi

if [[ ${#staged_files[@]} -gt 0 ]]; then
  printf '%s\0' "${staged_files[@]}" | xargs -0 -r editorconfig-checker
fi

workflow_files=()
for file in "${staged_files[@]}"; do
  case "$file" in
    .github/workflows/*.yml | .github/workflows/*.yaml)
      workflow_files+=("$file")
      ;;
  esac
done

if [[ ${#workflow_files[@]} -gt 0 ]]; then
  # GitHub Actions workflow チェック (staged workflow ファイルのみ)
  if ! command -v actionlint &>/dev/null; then
    echo "actionlint is not installed. Cannot GitHub Actions workflow check."
    exit 1
  fi

  actionlint "${workflow_files[@]}"
fi

# markdown リンクチェック (staged .md ファイルのみ)
markdown_files=()
for file in "${staged_files[@]}"; do
  [[ "$file" == *.md ]] || continue
  markdown_files+=("$file")
done

if [[ ${#markdown_files[@]} -gt 0 ]]; then
  if ! command -v markdown-link-check &>/dev/null; then
    echo "markdown-link-check is not installed. Cannot markdown link check."
    exit 1
  fi

  .github/scripts/check-markdown-links.sh "${markdown_files[@]}"
fi

# ステージされた .sh ファイルに実行権限があるか確認する
missing_exec=()
for file in "${staged_files[@]}"; do
  [[ "$file" == *.sh ]] || continue
  if [[ -f "$file" ]] && ! [[ -x "$file" ]]; then
    missing_exec+=("$file")
  fi
done

if [[ ${#missing_exec[@]} -gt 0 ]]; then
  echo "Error: The following shell scripts are missing execute permission:"
  for f in "${missing_exec[@]}"; do
    echo "  $f"
  done
  echo "Run: chmod +x <file> and re-stage."
  exit 1
fi
