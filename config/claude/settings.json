{
  "worktreeConfig": {
    "enabled": true
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "example-skills@anthropic-agent-skills": true
  },
  "effortLevel": "low",
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(ls *)",
      "Bash(tree *)",
      "Bash(mkdir *)",
      "Bash(git status *)",
      "Bash(git -C * status *)",
      "Bash(git diff *)",
      "Bash(git -C * diff *)",
      "Bash(pwd)",
      "Bash(cd *)",
      "Bash(git log *)",
      "Bash(git -C * log *)",
      "Bash(git branch *)",
      "Bash(git -C * branch *)",
      "Bash(git fetch *)",
      "Bash(git -C * fetch *)",
      "Bash(git switch *)",
      "Bash(git -C * switch *)",
      "Bash(git pull *)",
      "Bash(git -C * pull *)",
      "Bash(git add *)",
      "Bash(git -C * add *)",
      "Bash(git commit *)",
      "Bash(git -C * commit *)",
      "Bash(shellcheck *)",
      "Bash(nixfmt *)",
      "Bash(home-manager build *)",
      "Bash(nix *)",
      "Bash(nix-build *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list)",
      "Bash(gh issue list *)",
      "Bash(gh issue edit *)",
      "Bash(gh pr list)",
      "Bash(gh pr list *)",
      "Bash(gh label create *)",
      "Bash(gh pr view *)",
      "Bash(gh run view *)",
      "Bash(gh run list *)",
      "Bash(docker buildx build *)",
      "Bash(docker build)",
      "Bash(docker ps *)",
      "Bash(docker images *)",
      "Bash(sbt *)",
      "Bash(sbtn *)",
      "Bash(cargo *)",
      "WebFetch",
      "WebSearch"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(wget *)",
      "Bash(cat *)",
      "Bash(curl *)",
      "Bash(git push *)",
      "Bash(git -C * push *)",
      "Bash(git stash *)",
      "Bash(git -C * stash *)",
      "Bash(git rm *)",
      "Bash(git -C * rm *)",
      "Bash(gh pr create *)",
      "Bash(gh issue comment *)"
    ],
    "deny": [
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(sudo *)",
      "Bash(nc *)",
      "Bash(doppler *)",
      "Bash(git reset --hard *)",
      "Bash(git -C * reset --hard *)",
      "Read(.env.*)",
      "Read(~/.ssh/**)",
      "Edit(.env*)",
      "Edit(~/.ssh/**)"
    ]
  }
}
